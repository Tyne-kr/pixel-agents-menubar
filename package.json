{
  "name": "pixel-agents-menubar",
  "version": "0.1.0",
  "description": "Pixel art office visualization for AI coding agents — macOS menubar app",
  "main": "dist/main.js",
  "scripts": {
    "dev": "npm run build:main && electron .",
    "build:main": "esbuild src-electron/main.ts --bundle --platform=node --outfile=dist/main.js --external:electron --format=cjs",
    "build:preload": "esbuild src-electron/preload.ts --bundle --platform=node --outfile=dist/preload.js --external:electron --format=cjs",
    "build:renderer": "cd webview-ui && npx vite build",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "package": "npm run build && electron-builder --mac",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@types/node": "^20.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.27.0",
    "eslint": "^9.0.0",
    "typescript": "^5.9.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "pngjs": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "build": {
    "appId": "com.pixel-agents.menubar",
    "productName": "Pixel Agents",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "webview-ui/public/assets",
        "to": "assets"
      }
    ]
  }
}
